---
import Base from '../layouts/Base.astro';
import { loadBracketIndex } from '../lib/data-loader.ts';
const brackets = loadBracketIndex();
---
<Base title="Page not found — towrating.net" description="The page you're looking for doesn't exist or has moved.">
  <section class="max-w-3xl mx-auto px-4 py-16 text-center">
    <h1 class="font-display text-5xl font-bold text-brand-900 mb-4">404</h1>
    <p class="text-xl text-slate-700 mb-8">The page you're looking for doesn't exist. Try one of these:</p>
    <div class="grid sm:grid-cols-2 gap-3 mb-8">
      <a href="/" class="rounded-lg border border-slate-200 bg-white p-4 hover:border-accent-500 transition font-semibold text-brand-900">Home</a>
      <a href="/tow-by-capacity/" class="rounded-lg border border-slate-200 bg-white p-4 hover:border-accent-500 transition font-semibold text-brand-900">Tow by capacity</a>
      <a href="/tow-by-vehicle-type/" class="rounded-lg border border-slate-200 bg-white p-4 hover:border-accent-500 transition font-semibold text-brand-900">Tow by vehicle type</a>
      <a href="/guide/" class="rounded-lg border border-slate-200 bg-white p-4 hover:border-accent-500 transition font-semibold text-brand-900">Towing guides</a>
    </div>
    <h2 class="font-display text-2xl font-semibold mb-4">Or pick a capacity bracket:</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
      {brackets.map(b => (
        <a href={`/tow-by-capacity/${b.lbs}/`} class="rounded-md border border-slate-200 p-3 hover:border-accent-500 transition text-sm">{b.lbs.toLocaleString()} lbs</a>
      ))}
    </div>
  </section>
</Base>
